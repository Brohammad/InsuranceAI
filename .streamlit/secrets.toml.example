# .streamlit/secrets.toml.example
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for local dev OR
# paste the contents into Streamlit Community Cloud → App Settings → Secrets
#
# ⚠️  secrets.toml is in .gitignore — NEVER commit real keys to GitHub.
# ────────────────────────────────────────────────────────────────────────────

# Required — Google Gemini API key
GEMINI_API_KEY = "your_gemini_api_key_here"

# Set to "false" to use live Gemini calls (set "true" for demo/mock mode)
MOCK_DELIVERY = "false"

# Optional — model overrides (defaults are already set in core/config.py)
# GEMINI_MODEL_ORCHESTRATOR = "gemini-2.5-pro"
# GEMINI_MODEL_EXECUTION    = "gemini-2.5-flash"
# GEMINI_MODEL_CRITIQUE     = "gemini-2.5-pro"
# GEMINI_MODEL_SAFETY       = "gemini-2.5-flash"
# GEMINI_MODEL_CLASSIFY     = "gemini-2.5-flash"
# GEMINI_MODEL_REPORT       = "gemini-2.5-flash"

# Optional — Twilio (WhatsApp delivery)
# TWILIO_ACCOUNT_SID   = ""
# TWILIO_AUTH_TOKEN    = ""

# Optional — Razorpay (payment links)
# RAZORPAY_KEY_ID      = ""
# RAZORPAY_KEY_SECRET  = ""

# Optional — ElevenLabs (voice TTS)
# ELEVENLABS_API_KEY   = ""

# Optional — Sarvam AI (Indian-language TTS)
# SARVAM_API_KEY       = ""
